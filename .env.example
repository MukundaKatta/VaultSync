# VaultSync configuration
# Copy this file to .env and fill in your values

# Encryption key for secret values (required for encrypt/decrypt commands)
VAULTSYNC_ENCRYPTION_KEY=your-encryption-key-here

# Default export format: json | yaml | shell
VAULTSYNC_EXPORT_FORMAT=json

# Log level: DEBUG | INFO | WARNING | ERROR
VAULTSYNC_LOG_LEVEL=INFO

# Example application variables
DATABASE_URL=postgres://user:password@localhost:5432/mydb
REDIS_URL=redis://localhost:6379/0
API_SECRET_KEY=change-me
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
